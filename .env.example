# ╔══════════════════════════════════════════════════════╗
# ║    MAA JEWELLERS — Environment Configuration         ║
# ║    Rename this file to .env before running           ║
# ╚══════════════════════════════════════════════════════╝

# ── MongoDB Connection ──────────────────────────────────
# Local MongoDB (default — works out of the box if MongoDB installed)
MONGO_URI=mongodb://localhost:27017/maajewellers

# OR use MongoDB Atlas (free cloud DB — recommended for hosting)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/maajewellers?retryWrites=true&w=majority

# ── Server Port ─────────────────────────────────────────
PORT=5000

# ── JWT Secret ──────────────────────────────────────────
# Change this to a long, random string before deploying!
JWT_SECRET=MaaJewellers_Super_Secret_Key_2024_Change_This!

# ── Admin Credentials ───────────────────────────────────
# These are the login credentials for the owner dashboard
ADMIN_USERNAME=Harsh
ADMIN_PASSWORD=MaaJewellers@2024

# ── Frontend URL (for CORS) ──────────────────────────────
# For local development:
FRONTEND_URL=http://127.0.0.1:5500
# For production (your deployed frontend URL):
# FRONTEND_URL=https://your-site.netlify.app
